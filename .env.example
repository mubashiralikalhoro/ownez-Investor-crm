# Data Provider: "mock" (default) or "neon"
DATA_PROVIDER=mock

# Neon Postgres connection string (required when DATA_PROVIDER=neon)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Seed passwords (required on first deploy with DATA_PROVIDER=neon)
# SEED_PASSWORD_CHAD=
# SEED_PASSWORD_KEN=
# SEED_PASSWORD_ERIC=
# SEED_PASSWORD_EFRI=
