# Site origin with no trailing slash — must match the URL registered in Zoho API Console
# for the Authorized Redirect URI: {this value}/callbacks/zoho
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: server-only override (otherwise NEXT_PUBLIC_APP_URL is used)
# APP_URL=https://your-production-domain.com

# Zoho OAuth (server-side — never expose client_secret to the browser)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# Session JWT (HS256) — min 16 chars. Role is verified server-side; users cannot elevate by editing localStorage.
JWT_SECRET=asdfasdfaasdf23dafaeewaefawefasdc3AsdfasA12312S@sadf@dfasdfaSFasd
# Optional alias for JWT_SECRET
# SESSION_SECRET=

# Optional: session cookie lifetime in seconds (default 604800 = 7d)
# SESSION_JWT_MAX_AGE_SEC=604800

# Role access control — comma-separated Zoho role IDs (exact match).
# Find a role ID: log in → check zoho_user in localStorage → role.id
# Users whose role.id is not in either list are denied access.
ZOHO_ADMIN_ROLE_IDS=
ZOHO_REP_ROLE_IDS=

# Optional: regional accounts host (default US)
# ZOHO_ACCOUNTS_HOST=https://accounts.zoho.com
# EU example: https://accounts.zoho.eu
